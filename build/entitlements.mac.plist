<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron/V8 need JIT and writable+executable memory under the hardened runtime. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Required so the hardened, signed app can load active-win's native binary,
       which is not signed by our Developer ID. Without this, capture fails to
       load on a notarized build. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
